# Copy this file to .env and add real secrets there.
# .env is ignored by git.

# Provider: ollama or openai. Keep ollama here unless you want OpenAI as the default.
LLM_PROVIDER=ollama

# OpenAI provider settings
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=

# Ollama provider settings (used when LLM_PROVIDER=ollama or --provider ollama)
OLLAMA_MODEL=gpt-oss:120b
OLLAMA_BASE_URL=http://localhost:11434
